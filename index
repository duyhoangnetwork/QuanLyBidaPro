<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.5, user-scalable=yes, viewport-fit=cover">
  <title>Bida Pro • Quản lý chuyên nghiệp</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap');
    @import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css');

    /* CSS Variables – Dark theme mặc định */
    :root {
      --bg: #0b0a0c;
      --text: #f0eae0;
      --accent: #d4a853;
      --card-bg: rgba(30, 26, 22, 0.7);
      --glass-bg: rgba(20, 18, 24, 0.65);
      --glass-border: rgba(255, 255, 255, 0.1);
      --text-secondary: #b0a89c;
      --input-bg: rgba(255, 255, 255, 0.07);
      --nav-bg: rgba(18, 16, 20, 0.8);
      --btn-primary: #b8861e;
      --danger: #c44545;
      --success: #3a8c5c;
      --warning: #c98a1c;
      --radius: 18px;
      --radius-sm: 12px;
      --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      --playing-border: #2ecc71;
      --idle-border: #e74c3c;
    }

    /* Theme colors – mỗi theme sẽ ghi đè các biến */
    body.theme-light {
      --bg: #f5efe0;
      --text: #3a3026;
      --accent: #b8860b;
      --card-bg: rgba(255, 250, 240, 0.8);
      --glass-bg: rgba(255, 250, 240, 0.7);
      --glass-border: rgba(0,0,0,0.1);
      --text-secondary: #5c5346;
      --input-bg: rgba(0,0,0,0.05);
      --nav-bg: rgba(240, 230, 210, 0.85);
      --btn-primary: #b8860b;
    }
    body.theme-green {
      --bg: #0a1a0a;
      --text: #d0e8d0;
      --accent: #60b848;
      --card-bg: rgba(20,40,20,0.7);
      --glass-bg: rgba(15,30,15,0.7);
      --glass-border: rgba(255,255,255,0.1);
      --text-secondary: #90b090;
      --input-bg: rgba(255,255,255,0.05);
      --nav-bg: rgba(10,20,10,0.8);
      --btn-primary: #408020;
    }
    body.theme-ocean {
      --bg: #0a1628;
      --text: #d0e0f0;
      --accent: #5090e0;
      --card-bg: rgba(20,30,50,0.7);
      --glass-bg: rgba(15,25,40,0.7);
      --glass-border: rgba(255,255,255,0.1);
      --text-secondary: #8090b0;
      --input-bg: rgba(255,255,255,0.05);
      --nav-bg: rgba(10,20,40,0.8);
      --btn-primary: #3060b0;
    }
    body.theme-fire {
      --bg: #1a0a05;
      --text: #f0d0c0;
      --accent: #e06030;
      --card-bg: rgba(40,20,10,0.7);
      --glass-bg: rgba(30,15,10,0.7);
      --glass-border: rgba(255,255,255,0.1);
      --text-secondary: #c09080;
      --input-bg: rgba(255,255,255,0.05);
      --nav-bg: rgba(20,10,5,0.8);
      --btn-primary: #c04020;
    }
    body.theme-purple {
      --bg: #180a20;
      --text: #e0d0f0;
      --accent: #b050e0;
      --card-bg: rgba(30,20,40,0.7);
      --glass-bg: rgba(25,15,35,0.7);
      --glass-border: rgba(255,255,255,0.1);
      --text-secondary: #a090c0;
      --input-bg: rgba(255,255,255,0.05);
      --nav-bg: rgba(20,10,30,0.8);
      --btn-primary: #8030b0;
    }
    body.theme-gold {
      --bg: #1a1405;
      --text: #ffe7a0;
      --accent: #ffd700;
      --card-bg: rgba(40,30,10,0.7);
      --glass-bg: rgba(30,25,10,0.7);
      --glass-border: rgba(255,255,255,0.1);
      --text-secondary: #c0b080;
      --input-bg: rgba(255,255,255,0.05);
      --nav-bg: rgba(20,15,5,0.8);
      --btn-primary: #b8960a;
    }
    body.theme-sunset {
      --bg: #2a0a05;
      --text: #f0d0c0;
      --accent: #ff7040;
      --card-bg: rgba(40,20,10,0.7);
      --glass-bg: rgba(35,15,10,0.7);
      --glass-border: rgba(255,255,255,0.1);
      --text-secondary: #c09080;
      --input-bg: rgba(255,255,255,0.05);
      --nav-bg: rgba(25,10,5,0.8);
      --btn-primary: #cc4020;
    }
    body.theme-mint {
      --bg: #0a1a15;
      --text: #d0f0e0;
      --accent: #50d090;
      --card-bg: rgba(20,40,30,0.7);
      --glass-bg: rgba(15,30,20,0.7);
      --glass-border: rgba(255,255,255,0.1);
      --text-secondary: #80c0a0;
      --input-bg: rgba(255,255,255,0.05);
      --nav-bg: rgba(10,20,15,0.8);
      --btn-primary: #208050;
    }
    body.theme-midnight {
      --bg: #0a0a1a;
      --text: #d0d0f0;
      --accent: #7070f0;
      --card-bg: rgba(20,20,40,0.7);
      --glass-bg: rgba(15,15,30,0.7);
      --glass-border: rgba(255,255,255,0.1);
      --text-secondary: #9090c0;
      --input-bg: rgba(255,255,255,0.05);
      --nav-bg: rgba(10,10,25,0.8);
      --btn-primary: #4040b0;
    }

    * { margin:0; padding:0; box-sizing:border-box; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding-bottom: 100px;
      transition: background 0.4s, color 0.4s;
      overflow-x: hidden;
      -webkit-tap-highlight-color: transparent;
    }
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: radial-gradient(ellipse at 20% 20%, rgba(212,168,83,0.07) 0%, transparent 55%),
                  radial-gradient(ellipse at 80% 70%, rgba(180,130,60,0.04) 0%, transparent 55%);
      pointer-events: none;
      z-index: 0;
    }

    /* Glass mode sử dụng biến glass-bg */
    body.glass-mode .glass-card,
    body.glass-mode .modal-content,
    body.glass-mode .nav-bar,
    body.glass-mode .header-card,
    body.glass-mode .table-card,
    body.glass-mode .stat-card,
    body.glass-mode .about-section,
    body.glass-mode .support-block,
    body.glass-mode .history-card,
    body.glass-mode .revenue-card {
      background: rgba(255, 255, 255, 0.07);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.16);
    }
    body.glass-mode .nav-bar {
      background: rgba(10, 8, 12, 0.5);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
    }

    body.space-bg {
      background: #03030a;
      background-image: radial-gradient(ellipse at 30% 30%, rgba(30,20,60,0.7) 0%, transparent 60%),
                        radial-gradient(ellipse at 70% 60%, rgba(20,30,60,0.6) 0%, transparent 60%),
                        radial-gradient(ellipse at 50% 90%, rgba(60,40,80,0.4) 0%, transparent 50%);
    }
    body.space-bg .stars {
      position: fixed; inset:0; background:transparent; z-index:0; pointer-events:none;
    }

    .page {
      display: none;
      width: 100%;
      max-width: 640px;
      padding: 12px 12px 16px;
      margin: 0 auto;
      position: relative;
      z-index: 2;
      animation: fadeSlideIn 0.3s ease;
    }
    .page.active { display: block; }
    @keyframes fadeSlideIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .header-card {
      background: var(--glass-bg);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius);
      padding: 14px 12px;
      margin-bottom: 12px;
      box-shadow: 0 6px 24px rgba(0,0,0,0.4), 0 0 14px rgba(212,168,83,0.45);
      text-align: center;
    }
    .shop-name {
      font-family: 'Dancing Script', cursive;
      font-size: 2rem;
      color: var(--accent);
      text-shadow: 0 0 10px var(--accent);
      letter-spacing: 1.5px;
      margin-bottom: 2px;
    }
    .rate-badge {
      display: inline-block;
      background: rgba(212,168,83,0.12);
      padding: 4px 14px;
      border-radius: 24px;
      font-weight: 600;
      font-size: 0.8rem;
      color: var(--accent);
      margin-top: 4px;
    }
    .slogan {
      font-size: 0.7rem;
      opacity: 0.8;
      margin-top: 6px;
      color: var(--text-secondary);
    }

    .tables-grid {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    body.compact-mode .tables-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
    .table-card {
      background: var(--card-bg);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-radius: var(--radius);
      padding: 10px;
      transition: all var(--transition);
      cursor: default;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      border: 2px solid var(--glass-border);
      box-shadow: 0 3px 14px rgba(0,0,0,0.3);
    }
    .table-card.status-playing {
      border-color: var(--playing-border);
      box-shadow: 0 0 20px rgba(46,204,113,0.5);
    }
    .table-card.status-idle {
      border-color: var(--idle-border);
      box-shadow: 0 0 14px rgba(231,76,60,0.4);
    }

    .table-top { width:100%; display:flex; justify-content:center; }
    .table-name { font-weight: 700; font-size: 1rem; }
    .table-middle { width:100%; }
    .timer-large {
      font-family: 'Dancing Script', cursive;
      font-size: 1.9rem;
      text-align: center;
      color: #ffd78b;
      text-shadow: 0 0 6px rgba(212,168,83,0.7);
      letter-spacing: 1.5px;
    }
    .table-bottom { width:100%; display:flex; justify-content:center; }
    .badge {
      padding: 4px 14px;
      border-radius: 20px;
      font-size: 0.7rem;
      font-weight: 700;
      background: rgba(0,0,0,0.4);
      border: 1px solid;
    }
    .badge.playing {
      color: var(--playing-border);
      border-color: var(--playing-border);
    }
    .badge.idle {
      color: var(--idle-border);
      border-color: var(--idle-border);
    }
    .price-text { font-weight: 600; color: var(--accent); font-size: 0.8rem; }
    .items-mini { font-size: 0.7rem; max-height: 50px; overflow-y: auto; margin: 4px 0; opacity: 0.9; }
    .total-row { display: flex; justify-content: space-between; font-weight: 700; font-size:0.8rem; }
    .btn-row { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 4px; }

    body.compact-mode .price-text,
    body.compact-mode .items-mini,
    body.compact-mode .total-row,
    body.compact-mode .btn-row { display: none; }
    body.compact-mode .table-card { padding: 8px 6px; min-height: 80px; cursor:pointer; }

    button {
      border: none;
      padding: 8px 14px;
      border-radius: 30px;
      font-weight: 600;
      font-size: 0.8rem;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
      transition: all 0.2s;
      background: var(--btn-primary);
      color: #fff;
      box-shadow: 0 2px 6px rgba(0,0,0,0.2);
      position: relative;
      overflow: hidden;
    }
    button:active { transform: scale(0.96); }
    button.danger { background: var(--danger); }
    button.success { background: var(--success); }
    button.warning { background: var(--warning); color: #000; }
    button.outline { background: transparent; border: 1.5px solid var(--accent); color: var(--accent); }

    /* Bottom nav */
    .nav-bar {
      position: fixed;
      bottom: 10px;
      left: 50%;
      transform: translateX(-50%);
      width: calc(100% - 24px);
      max-width: 520px;
      background: var(--nav-bg);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-radius: 40px;
      padding: 4px 4px;
      display: flex;
      justify-content: space-around;
      align-items: center;
      z-index: 1000;
      box-shadow: 0 10px 22px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.08);
    }
    .nav-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      color: var(--text-secondary);
      font-size: 0.6rem;
      font-weight: 500;
      gap: 2px;
      background: transparent;
      border: none;
      padding: 5px 8px;
      border-radius: 28px;
      cursor: pointer;
      position: relative;
      overflow: hidden;
      min-width: 44px;
    }
    .nav-item i { font-size: 1.1rem; }
    .nav-item.active { color: var(--accent); font-weight: 700; background: rgba(212,168,83,0.15); }
    .nav-item .ripple-bubble {
      position: absolute;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.25);
      transform: scale(0);
      animation: bubbleRipple 0.55s ease-out forwards;
      pointer-events: none;
    }
    @keyframes bubbleRipple { to { transform: scale(4); opacity: 0; } }

    /* History & Revenue cards */
    .history-day-group { margin-bottom: 16px; }
    .history-day-title { font-weight: 700; color: var(--accent); margin-bottom: 8px; font-size: 0.9rem; }
    .history-card {
      background: var(--glass-bg); backdrop-filter: blur(14px); border: 1px solid var(--glass-border);
      border-radius: var(--radius-sm); padding: 10px; margin-bottom: 8px; font-size: 0.75rem;
      display: flex; flex-direction: column; gap: 4px;
    }
    .history-card-row { display: flex; justify-content: space-between; }
    .revenue-card {
      background: var(--glass-bg); backdrop-filter: blur(14px); border: 1px solid var(--glass-border);
      border-radius: var(--radius-sm); padding: 12px; margin-bottom: 8px; font-size: 0.8rem;
    }

    /* Greeting modal */
    .greeting-modal-overlay {
      position: fixed; inset:0; background: rgba(0,0,0,0.5);
      backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
      z-index:4000; display:flex; align-items:center; justify-content:center;
      padding:20px; opacity:0; visibility:hidden; transition:0.3s;
    }
    .greeting-modal-overlay.show { opacity:1; visibility:visible; }
    .greeting-modal-content {
      background: rgba(20,18,24,0.8); backdrop-filter: blur(20px);
      border:1px solid var(--accent); border-radius:28px; padding:24px;
      text-align:center; max-width:380px; width:100%;
      box-shadow:0 20px 40px rgba(0,0,0,0.6);
      transform:scale(0.9); transition:0.35s;
    }
    .greeting-modal-overlay.show .greeting-modal-content { transform:scale(1); }
    .greeting-shop-name { font-family:'Dancing Script',cursive; font-size:2rem; color:var(--accent); }
    .greeting-text { font-size:1rem; margin:12px 0; }
    .greeting-close { margin-top:14px; background:transparent; border:1px solid var(--accent); color:var(--accent); padding:8px 20px; border-radius:20px; }

    /* Other modals */
    .modal-overlay {
      position: fixed; inset:0; background: rgba(0,0,0,0.7);
      backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
      z-index:2000; display:flex; align-items:center; justify-content:center;
      padding:16px; opacity:0; visibility:hidden; transition:0.3s;
    }
    .modal-overlay.show { opacity:1; visibility:visible; }
    .modal-content {
      background: var(--glass-bg); backdrop-filter: blur(20px);
      border:1px solid var(--glass-border); border-radius:24px; padding:18px;
      width:100%; max-width:420px; max-height:80vh; overflow-y:auto;
      box-shadow:0 16px 32px rgba(0,0,0,0.6);
      transform: scale(0.93); transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
    }
    .modal-overlay.show .modal-content { transform: scale(1); }

    .toast-container {
      position:fixed; top:16px; left:50%; transform:translateX(-50%);
      z-index:3000; display:flex; flex-direction:column; gap:6px; pointer-events:none;
    }
    .toast {
      background:rgba(20,18,24,0.9); backdrop-filter:blur(10px);
      border:1px solid var(--accent); color:var(--text);
      padding:10px 20px; border-radius:30px; font-weight:600; font-size:0.8rem;
      box-shadow:0 6px 16px rgba(0,0,0,0.4);
      animation: slideDown 0.4s ease, fadeOut 0.4s 2.2s forwards;
      white-space:nowrap; text-align:center;
    }
    @keyframes slideDown { from{opacity:0;transform:translateY(-16px);} to{opacity:1;transform:translateY(0);} }
    @keyframes fadeOut { to{opacity:0;transform:translateY(-8px);} }

    input, select {
      background: var(--input-bg); border:1px solid rgba(255,255,255,0.15);
      border-radius:24px; padding:8px 12px; color:var(--text); font-size:0.85rem; outline:none; width:100%;
    }
    .toggle-switch { position:relative; display:inline-block; width:46px; height:26px; }
    .toggle-switch input { display:none; }
    .slider { position:absolute; inset:0; background:#555; border-radius:26px; transition:0.3s; }
    .slider::before { content:''; position:absolute; height:20px; width:20px; left:3px; bottom:3px; background:white; border-radius:50%; transition:0.3s; }
    input:checked+.slider { background:var(--accent); }
    input:checked+.slider::before { transform:translateX(20px); }
    .stat-card {
      background: var(--glass-bg); backdrop-filter: blur(14px);
      border-radius: var(--radius-sm); padding:12px; border:1px solid var(--glass-border);
    }
    .about-section, .support-block {
      margin-top: 14px; background: var(--glass-bg); backdrop-filter: blur(14px);
      border: 1px solid var(--glass-border); border-radius: var(--radius); padding: 14px;
      font-size: 0.8rem; line-height: 1.5; color: var(--text-secondary); box-shadow: 0 6px 24px rgba(0,0,0,0.4);
    }
    .contact-buttons { display: flex; flex-wrap: wrap; gap: 10px; margin: 12px 0; }
    .contact-btn {
      display: flex; align-items: center; gap: 6px; padding: 10px 16px;
      border-radius: 30px; background: var(--btn-primary); color: #fff;
      text-decoration: none; font-weight: 600; font-size: 0.85rem; transition: 0.2s;
      box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }
    .contact-btn.zalo { background: #0180c7; }
    .contact-btn.hotline { background: #e04848; }
    .contact-btn.email { background: #4a8c4a; }

    .top-actions { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; gap: 8px; }
    .btn-about {
      background: transparent; border: 1.5px solid var(--accent); color: var(--accent);
      padding: 6px 14px; font-size: 0.75rem; border-radius: 30px; cursor: pointer;
      display: flex; align-items: center; gap: 5px; font-weight: 600;
    }
  </style>
</head>
<body class="">
  <canvas class="stars" id="starsCanvas" style="display:none;"></canvas>
  <div class="toast-container" id="toastContainer"></div>

  <!-- Greeting Modal -->
  <div class="greeting-modal-overlay" id="greetingModal">
    <div class="greeting-modal-content">
      <div class="greeting-shop-name" id="greetingShopName">BIDA PRO</div>
      <div class="greeting-text" id="greetingMessage"></div>
      <button class="greeting-close" id="greetingCloseBtn">✨ Đã hiểu</button>
    </div>
  </div>

  <!-- PAGE HOME -->
  <div class="page active" id="page-home">
    <div class="header-card glass-card">
      <div class="shop-name" id="shopNameDisplay">BIDA PRO</div>
      <div class="rate-badge" id="rateDisplay">50.000đ / giờ</div>
      <div class="slogan">Quản lý chuyên nghiệp • Tính giờ chính xác • Giao diện hiện đại • Hỗ trợ tận tâm</div>
    </div>
    <div class="top-actions">
      <button id="btnAbout" class="btn-about"><i class="fas fa-info-circle"></i> Biết thêm</button>
      <button id="toggleCompactBtn" class="outline" style="padding:6px 14px; font-size:0.75rem;">
        <i class="fas fa-expand-alt"></i> <span id="compactLabel">Thu nhỏ</span>
      </button>
    </div>
    <div class="tables-grid" id="tablesGrid"></div>
  </div>

  <!-- PAGE ABOUT -->
  <div class="page" id="page-about">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
      <h2>📖 Giới thiệu</h2>
      <button id="btnBackFromAbout" class="outline" style="padding:6px 14px; font-size:0.8rem;"><i class="fas fa-arrow-left"></i> Quay lại</button>
    </div>
    <div class="about-section glass-card">
