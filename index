      <div class="table-middle"><div class="timer-large">${fmtTime(sec)}</div></div>
      <div class="table-bottom"><span class="badge ${t.status==='playing'?'playing':'idle'}">${t.status==='playing'?'Đang chơi':'Trống'}</span></div>
      ${!compactMode?`<div class="price-text">💰 Giờ: ${fmtMoney(price)}</div>
      <div class="items-mini">${t.items.length?t.items.map(i=>`<div>${i.icon||''} ${i.name} x${i.qty} = ${fmtMoney(i.price*i.qty)}</div>`).join(''):'<em>Chưa có đồ</em>'}</div>
      <div class="total-row"><span>🧾 Tổng:</span><span>${fmtMoney(price+t.totalItems)}</span></div>
      <div class="btn-row">${t.status==='idle'?`<button class="success start-btn" data-id="${t.id}"><i class="fas fa-play"></i> Bắt đầu</button>`:`<button class="warning add-btn" data-id="${t.id}"><i class="fas fa-plus"></i> Thêm đồ</button><button class="danger checkout-btn" data-id="${t.id}"><i class="fas fa-cash-register"></i> Tính tiền</button>`}</div>`:''}`;
      if(compactMode){card.addEventListener('click',e=>{if(e.target.closest('button'))return;openDetailModal(t.id);});}
      grid.appendChild(card);
    });
    $$('.start-btn').forEach(b=>b.onclick=()=>startTable(+b.dataset.id));
    $$('.add-btn').forEach(b=>b.onclick=()=>openAddItemModal(+b.dataset.id));
    $$('.checkout-btn').forEach(b=>b.onclick=()=>checkout(+b.dataset.id));
    }
    function startTable(id){const t=tables.find(x=>x.id===id);if(!t||t.status!=='idle')return;t.status='playing';t.startTime=Date.now();t.items=[];t.totalItems=0;saveAll();startTimer(id);renderAllTables();}
    function checkout(id){const t=tables.find(x=>x.id===id);if(!t||t.status!=='playing')return;if(t.interval){clearInterval(t.interval);t.interval=null;}const endTime=Date.now();const sec=Math.floor((endTime-t.startTime)/1000);const price=calcTimePrice(sec);const total=price+t.totalItems;pendingCheckout={tableId:id,startTime:t.startTime,endTime,sec,price,items:[...t.items],totalItems:t.totalItems,total};$('#checkoutModalContent').innerHTML=`<h3>💰 Tính tiền - Bàn ${id}</h3><p>⏱ Chơi: ${fmtTime(sec)}</p><p>💵 Tiền giờ: ${fmtMoney(price)}</p><p>🍽 Đồ: ${fmtMoney(t.totalItems)}</p><p><strong>Tổng: ${fmtMoney(total)}</strong></p><div style="display:flex; gap:8px; margin-top:10px;"><button id="cashBtn" class="success">💵 Tiền mặt</button><button id="qrBtn" class="primary">📱 QR Bank</button></div><button id="cancelCheckoutBtn" class="danger" style="margin-top:6px;">Hủy</button>`;$('#checkoutModal').classList.add('show');document.getElementById('cashBtn').onclick=()=>finalizePayment('Tiền mặt');document.getElementById('qrBtn').onclick=showQR;document.getElementById('cancelCheckoutBtn').onclick=()=>{$('#checkoutModal').classList.remove('show');if(pendingCheckout){const tb=tables.find(x=>x.id===pendingCheckout.tableId);if(tb&&tb.status==='playing')startTimer(tb.id);pendingCheckout=null;}};}
    function finalizePayment(method){if(!pendingCheckout)return;const p=pendingCheckout;history.unshift({tableId:p.tableId,startTime:p.startTime,endTime:p.endTime,duration:p.sec,priceTime:p.price,items:p.items,total:p.total,method,createdAt:Date.now()});const t=tables.find(x=>x.id===p.tableId);if(t){t.status='idle';t.startTime=null;t.items=[];t.totalItems=0;if(t.interval){clearInterval(t.interval);t.interval=null;}}saveAll();renderAllTables();renderHistory();renderRevenue();pendingCheckout=null;$('#checkoutModal').classList.remove('show');toast(`✅ Đã thanh toán bàn ${p.tableId} qua ${method}`);}
    function showQR(){if(!pendingCheckout)return;const amt=Math.floor(pendingCheckout.total);const d=new Date(pendingCheckout.startTime);const note=`TIEN BAN ${pendingCheckout.tableId} ${d.getDate().toString().padStart(2,'0')}/${(d.getMonth()+1).toString().padStart(2,'0')}/${d.getFullYear()}-${d.getHours().toString().padStart(2,'0')}/${d.getMinutes().toString().padStart(2,'0')}`;const url=`https://img.vietqr.io/image/${BANK_BIN}-${ACCOUNT_NO}-qr_only.jpg?accountName=${encodeURIComponent(ACCOUNT_NAME)}&amount=${amt}&addInfo=${encodeURIComponent(note)}`;$('#qrImage').src=url;$('#qrInfo').innerHTML=`Số tiền: ${fmtMoney(amt)}<br>Nội dung: ${note}`;$('#qrModal').classList.add('show');$('#checkoutModal').classList.remove('show');}

    function openAddItemModal(tableId){modalTableId=tableId;modalCart=[];renderAddItemModal();$('#addItemModal').classList.add('show');}
    function renderAddItemModal(){const content=$('#addItemModalContent');content.innerHTML=`<h3>➕ Thêm đồ - Bàn ${modalTableId}</h3><div id="modalItemList"></div><div id="modalCartBox" style="display:none; margin-top:8px; background:rgba(0,0,0,0.2); border-radius:14px; padding:8px;"><strong>🛒 Giỏ tạm:</strong><div id="modalCartItems"></div><div id="modalCartTotal" style="font-weight:700; text-align:right;"></div></div><div style="display:flex; gap:6px; justify-content:flex-end; margin-top:10px;"><button id="cancelAddItemBtn" class="danger">Hủy</button><button id="confirmAddItemBtn" class="primary">✅ Xác nhận</button></div>`;const listDiv=$('#modalItemList');listDiv.innerHTML=menu.map(m=>{const inCart=modalCart.find(c=>c.name===m.name);const qty=inCart?inCart.qty:0;return `<div style="display:flex; align-items:center; justify-content:space-between; padding:6px; border-bottom:1px solid rgba(255,255,255,0.1);"><span>${m.icon} ${m.name} - ${fmtK(m.price)}</span><div style="display:flex; align-items:center; gap:4px;"><button class="modal-minus" data-name="${m.name}">−</button><span>${qty}</span><button class="modal-plus" data-name="${m.name}" data-price="${m.price}" data-icon="${m.icon}">+</button></div></div>`;}).join('');document.getElementById('cancelAddItemBtn').onclick=()=>{$('#addItemModal').classList.remove('show');modalCart=[];};document.getElementById('confirmAddItemBtn').onclick=confirmAddItem;listDiv.querySelectorAll('.modal-plus').forEach(b=>b.onclick=()=>addToModalCart(b.dataset.name,+b.dataset.price,b.dataset.icon));listDiv.querySelectorAll('.modal-minus').forEach(b=>b.onclick=()=>removeFromModalCart(b.dataset.name));}
    function addToModalCart(name,price,icon){const ex=modalCart.find(c=>c.name===name);if(ex)ex.qty++;else modalCart.push({name,price,icon,qty:1});renderAddItemModal();}
    function removeFromModalCart(name){const ex=modalCart.find(c=>c.name===name);if(ex){ex.qty--;if(ex.qty<=0)modalCart=modalCart.filter(c=>c.name!==name);}renderAddItemModal();}
    function confirmAddItem(){if(!modalTableId||modalCart.length===0)return;const t=tables.find(x=>x.id===modalTableId);if(!t||t.status!=='playing')return;modalCart.forEach(c=>{const existing=t.items.find(i=>i.name===c.name);if(existing){existing.qty+=c.qty;}else{t.items.push({name:c.name,price:c.price,icon:c.icon,qty:c.qty});}t.totalItems+=c.price*c.qty;const qtyText=c.qty>1?` x${c.qty}`:'';toast(`✅ Đã thêm ${c.icon} ${c.name}${qtyText} vào Bàn ${modalTableId}`);});saveAll();renderAllTables();modalCart=[];$('#addItemModal').classList.remove('show');}

    function openDetailModal(id){$('#detailModal').dataset.tableId=id;renderDetailModalContent(id);$('#detailModal').classList.add('show');}
    function renderDetailModalContent(id){const t=tables.find(x=>x.id===id);if(!t)return;const sec=getElapsed(t),price=calcTimePrice(sec),total=price+t.totalItems;$('#detailModalContent').innerHTML=`<h3>🎱 Bàn ${id} <span class="badge ${t.status==='playing'?'playing':'idle'}">${t.status==='playing'?'Đang chơi':'Trống'}</span></h3><div class="timer-large" style="font-size:1.8rem;">${fmtTime(sec)}</div><p>💰 Giờ: ${fmtMoney(price)}</p><div>${t.items.length?t.items.map(i=>`<div>${i.icon||''} ${i.name} x${i.qty} = ${fmtMoney(i.price*i.qty)}</div>`).join(''):'<em>Chưa có đồ</em>'}</div><p><strong>🧾 Tổng: ${fmtMoney(total)}</strong></p><div style="display:flex; gap:6px; margin-top:10px;">${t.status==='idle'?`<button class="success" id="detailStartBtn">▶ Bắt đầu</button>`:`<button class="warning" id="detailAddBtn">➕ Thêm đồ</button><button class="danger" id="detailCheckoutBtn">💰 Tính tiền</button>`}</div><button id="closeDetailBtn" class="outline" style="margin-top:8px; width:100%;">Đóng</button>`;document.getElementById('detailStartBtn')?.addEventListener('click',()=>{startTable(id);$('#detailModal').classList.remove('show');});document.getElementById('detailAddBtn')?.addEventListener('click',()=>{$('#detailModal').classList.remove('show');openAddItemModal(id);});document.getElementById('detailCheckoutBtn')?.addEventListener('click',()=>{$('#detailModal').classList.remove('show');checkout(id);});document.getElementById('closeDetailBtn').onclick=()=>$('#detailModal').classList.remove('show');}

    function renderHistory(filter='all'){
      const data = filter==='all'?history:history.filter(h=>h.tableId===+filter);
      const container = $('#historyList');
      container.innerHTML = '';
      const grouped = {};
      data.forEach(h=>{
        const dayKey = new Date(h.createdAt || h.startTime).toLocaleDateString('vi-VN');
        if(!grouped[dayKey]) grouped[dayKey] = [];
        grouped[dayKey].push(h);
      });
      for(const [day, items] of Object.entries(grouped)){
        const groupDiv = document.createElement('div');
        groupDiv.className = 'history-day-group';
        groupDiv.innerHTML = `<div class="history-day-title">📅 ${day}</div>`;
        items.forEach(h=>{
          const card = document.createElement('div');
          card.className = 'history-card glass-card';
          card.innerHTML = `
            <div class="history-card-row"><span>🎱 Bàn ${h.tableId}</span><span>${h.method}</span></div>
            <div class="history-card-row"><span>⏱ ${fmtDate(h.startTime)} → ${fmtDate(h.endTime)}</span></div>
            <div class="history-card-row"><span>⏳ ${fmtTime(h.duration)}</span><span>💵 ${fmtMoney(h.priceTime)}</span></div>
            <div class="history-card-row"><span>🍽 ${h.items.map(i=>`${i.name} x${i.qty}`).join(', ')||'—'}</span></div>
            <div class="history-card-row"><strong>🧾 ${fmtMoney(h.total)}</strong></div>
          `;
          groupDiv.appendChild(card);
        });
        container.appendChild(groupDiv);
      }
      const sel = $('#filterTableSelect');
      sel.innerHTML = '<option value="all">Tất cả bàn</option>'+tables.map(t=>`<option value="${t.id}">Bàn ${t.id}</option>`).join('');
    }
    function exportTxt(){let c='LỊCH SỬ BIDA\n';history.forEach(h=>c+=`Bàn ${h.tableId} | ${fmtDate(h.startTime)} -> ${fmtDate(h.endTime)} | ${fmtTime(h.duration)} | Giờ:${fmtMoney(h.priceTime)} | Đồ:${h.items.map(i=>i.name+'x'+i.qty).join(',')||'Không'} | Tổng:${fmtMoney(h.total)}\n`);const b=new Blob([c],{type:'text/plain'});const a=document.createElement('a');a.href=URL.createObjectURL(b);a.download='lich_su_bida.txt';a.click();}
    function exportCsv(){let c='Bàn,Bắt đầu,Kết thúc,Giờ,Tiền giờ,Đồ,Tổng\n';history.forEach(h=>c+=`${h.tableId},"${fmtDate(h.startTime)}","${fmtDate(h.endTime)}",${fmtTime(h.duration)},${h.priceTime},"${h.items.map(i=>i.name+'x'+i.qty).join(';')}",${h.total}\n`);const b=new Blob([c],{type:'text/csv'});const a=document.createElement('a');a.href=URL.createObjectURL(b);a.download='lich_su_bida.csv';a.click();}

    function renderRevenue(){
      const now=Date.now();
      const todayStart=new Date().setHours(0,0,0,0);
      const monthStart=new Date(new Date().getFullYear(),new Date().getMonth(),1).getTime();
      let today=0,month=0,all=0;
      history.forEach(h=>{all+=h.total;if(h.createdAt>=todayStart)today+=h.total;if(h.createdAt>=monthStart)month+=h.total;});
      $('#statsSummary').innerHTML=`<div class="stat-card">📅 Hôm nay<br><strong>${fmtMoney(today)}</strong></div><div class="stat-card">📆 Tháng<br><strong>${fmtMoney(month)}</strong></div><div class="stat-card">📈 Tổng<br><strong>${fmtMoney(all)}</strong></div>`;
      const stats = {};
      tables.forEach(t=>stats[t.id]={count:0,sec:0,priceTime:0,itemsTotal:0});
      history.forEach(h=>{if(stats[h.tableId]){stats[h.tableId].count++;stats[h.tableId].sec+=h.duration;stats[h.tableId].priceTime+=h.priceTime;stats[h.tableId].itemsTotal+=h.items.reduce((s,i)=>s+i.price*i.qty,0);}});
      const container = $('#perTableStatsContainer');
      container.innerHTML = tables.map(t=>{
        const s=stats[t.id];
        return `<div class="revenue-card glass-card">
          <strong>🎱 Bàn ${t.id}</strong>
          <div style="display:flex; justify-content:space-between; margin-top:6px;"><span>Lượt chơi:</span><span>${s.count}</span></div>
          <div style="display:flex; justify-content:space-between;"><span>Tổng giờ:</span><span>${(s.sec/3600).toFixed(1)}h</span></div>
          <div style="display:flex; justify-content:space-between;"><span>Tiền giờ:</span><span>${fmtMoney(s.priceTime)}</span></div>
          <div style="display:flex; justify-content:space-between;"><span>Tiền đồ:</span><span>${fmtMoney(s.itemsTotal)}</span></div>
          <div style="display:flex; justify-content:space-between; font-weight:700;"><span>Tổng DT:</span><span>${fmtMoney(s.priceTime+s.itemsTotal)}</span></div>
        </div>`;
      }).join('');
      drawChart();
    }
    function drawChart(){const canvas=$('#revenueChart');if(!canvas)return;canvas.width=canvas.clientWidth||400;const ctx=canvas.getContext('2d');const days=[];for(let i=6;i>=0;i--){const d=new Date();d.setDate(d.getDate()-i);d.setHours(0,0,0,0);days.push(d.getTime());}const rev=days.map(ds=>history.reduce((s,h)=>h.createdAt>=ds&&h.createdAt<ds+86400000?s+h.total:s,0));const max=Math.max(...rev,10000);ctx.clearRect(0,0,canvas.width,canvas.height);const bw=(canvas.width-40)/7;ctx.fillStyle='#d4a853';rev.forEach((v,i)=>{const bh=(v/max)*(canvas.height-30);ctx.fillRect(20+i*bw,canvas.height-15-bh,bw-4,bh);});}

    function renderMenuPage(){const container=$('#menuListContainer');container.innerHTML=menu.map((m,idx)=>`<div class="stat-card" style="display:flex; justify-content:space-between; align-items:center;"><span>${m.icon} ${m.name} - <strong>${fmtMoney(m.price)}</strong></span><div><button class="edit-menu-btn warning" data-index="${idx}"><i class="fas fa-edit"></i></button><button class="delete-menu-btn danger" data-index="${idx}"><i class="fas fa-trash"></i></button></div></div>`).join('');$$('.edit-menu-btn').forEach(b=>b.onclick=()=>openMenuItemModal(+b.dataset.index));$$('.delete-menu-btn').forEach(b=>b.onclick=()=>{menu.splice(+b.dataset.index,1);saveAll();renderMenuPage();renderAllTables();toast('🗑 Đã xóa món');});}
    function openMenuItemModal(index=-1){editingMenuItemIndex=index;if(index>=0){const m=menu[index];$('#menuItemIcon').value=m.icon;$('#menuItemName').value=m.name;$('#menuItemPrice').value=m.price;$('#menuItemModalTitle').textContent='✏️ Chỉnh sửa món';}else{$('#menuItemIcon').value='';$('#menuItemName').value='';$('#menuItemPrice').value='';$('#menuItemModalTitle').textContent='➕ Thêm món mới';}$('#menuItemModal').classList.add('show');}
    function saveMenuItem(){const icon=$('#menuItemIcon').value.trim()||'🍽';const name=$('#menuItemName').value.trim();const price=parseInt($('#menuItemPrice').value);if(!name||isNaN(price)||price<=0){toast('❌ Vui lòng nhập đầy đủ thông tin');return;}if(editingMenuItemIndex>=0){menu[editingMenuItemIndex]={icon,name,price};}else{menu.push({icon,name,price});}saveAll();renderMenuPage();renderAllTables();$('#menuItemModal').classList.remove('show');toast('✅ Đã lưu món');}

    function applyTheme(theme){
      document.body.className = document.body.className.replace(/theme-\w+/g, '');
      if (theme !== 'dark') document.body.classList.add('theme-' + theme);
      localStorage.setItem('bida_pro_theme', theme);
    }
    function updateShopDisplay(){$('#shopNameDisplay').textContent=shopName;$('#rateDisplay').textContent=`${hourlyRate.toLocaleString('vi-VN')}đ / giờ`;$('#shopNameInput').value=shopName;$('#hourlyRateInput').value=hourlyRate;}

    function navigateTo(page){$$('.page').forEach(p=>p.classList.remove('active'));$(`#page-${page}`).classList.add('active');$$('.nav-item').forEach(n=>n.classList.remove('active'));const nav=document.querySelector(`.nav-item[data-page="${page}"]`);if(nav)nav.classList.add('active');if(page==='history')renderHistory();if(page==='revenue')renderRevenue();if(page==='menu')renderMenuPage();if(page==='settings')updateShopDisplay();}
    function createRipple(e,el){const r=document.createElement('span');r.className='ripple-bubble';const rect=el.getBoundingClientRect();const s=Math.max(rect.width,rect.height);r.style.width=r.style.height=`${s}px`;r.style.left=`${e.clientX-rect.left-s/2}px`;r.style.top=`${e.clientY-rect.top-s/2}px`;el.appendChild(r);r.addEventListener('animationend',()=>r.remove());}
    $$('.nav-item').forEach(b=>b.addEventListener('click',function(e){createRipple(e,this);navigateTo(this.dataset.page);}));

    function showGreetingModal(){const today=new Date().toDateString();if(localStorage.getItem('bida_greet_modal_date')===today)return;$('#greetingShopName').textContent=shopName;$('#greetingMessage').textContent=generateGreeting();$('#greetingModal').classList.add('show');localStorage.setItem('bida_greet_modal_date',today);}
    $('#greetingCloseBtn').addEventListener('click',()=>$('#greetingModal').classList.remove('show'));
    $('#greetingModal').addEventListener('click',function(e){if(e.target===this)this.classList.remove('show');});

    $('#btnAbout').addEventListener('click',()=>navigateTo('about'));
    $('#btnBackFromAbout').addEventListener('click',()=>navigateTo('home'));
    $('#toggleCompactBtn').addEventListener('click',()=>{compactMode=!compactMode;document.body.classList.toggle('compact-mode',compactMode);$('#compactLabel').textContent=compactMode?'Mở rộng':'Thu nhỏ';saveAll();renderAllTables();});
    $('#applyFilterBtn').addEventListener('click',()=>renderHistory($('#filterTableSelect').value));
    $('#exportTxtBtn').addEventListener('click',exportTxt);$('#exportCsvBtn').addEventListener('click',exportCsv);
    $('#deleteHistoryBtn').addEventListener('click',()=>$('#deleteModal').classList.add('show'));
    $('#cancelDeleteBtn').addEventListener('click',()=>$('#deleteModal').classList.remove('show'));
    $('#confirmDeleteBtn').addEventListener('click',()=>{if($('#deletePass').value===DELETE_PASS){history=[];saveAll();renderHistory();renderRevenue();$('#deleteModal').classList.remove('show');toast('🗑 Đã xóa lịch sử');}else toast('❌ Sai mật khẩu');});
    $('#confirmQrBtn').addEventListener('click',()=>{finalizePayment('QR Bank');$('#qrModal').classList.remove('show');});
    $('#closeQrBtn').addEventListener('click',()=>{$('#qrModal').classList.remove('show');$('#checkoutModal').classList.add('show');});
    $('#themeSelect').addEventListener('change',function(){applyTheme(this.value);});
    $('#glassToggle').addEventListener('change',function(){document.body.classList.toggle('glass-mode',this.checked);localStorage.setItem('bida_pro_glass',this.checked);});
    $('#spaceToggle').addEventListener('change',function(){document.body.classList.toggle('space-bg',this.checked);$('#starsCanvas').style.display=this.checked?'block':'none';localStorage.setItem('bida_pro_space',this.checked);if(this.checked)initStars();});
    $('#saveShopNameBtn').addEventListener('click',()=>{shopName=$('#shopNameInput').value.trim()||'BIDA PRO';saveAll();updateShopDisplay();toast('✅ Đã lưu tên quán');});
    $('#saveRateBtn').addEventListener('click',()=>{const v=parseInt($('#hourlyRateInput').value);if(!isNaN(v)&&v>=1000){hourlyRate=v;saveAll();updateShopDisplay();toast('✅ Đã cập nhật giá giờ');}else toast('❌ Giá không hợp lệ');});
    $('#addMenuItemBtn').addEventListener('click',()=>openMenuItemModal(-1));
    $('#saveMenuItemBtn').addEventListener('click',saveMenuItem);
    $('#cancelMenuItemBtn').addEventListener('click',()=>$('#menuItemModal').classList.remove('show'));
    $$('.modal-overlay').forEach(o=>o.addEventListener('click',function(e){if(e.target===this)this.classList.remove('show');}));

    function initStars(){const canvas=$('#starsCanvas');const ctx=canvas.getContext('2d');let stars=[];function resize(){canvas.width=window.innerWidth;canvas.height=window.innerHeight;stars=Array.from({length:80},()=>({x:Math.random()*canvas.width,y:Math.random()*canvas.height,r:Math.random()*1.8+0.5,speed:Math.random()*0.3+0.1}));}resize();window.addEventListener('resize',resize);function animate(){if(!document.body.classList.contains('space-bg'))return;ctx.clearRect(0,0,canvas.width,canvas.height);ctx.fillStyle='#fff';stars.forEach(s=>{ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);ctx.fill();s.y-=s.speed;if(s.y<-5){s.y=canvas.height+5;s.x=Math.random()*canvas.width;}});requestAnimationFrame(animate);}animate();}

    loadAll();updateShopDisplay();renderAllTables();renderHistory();renderRevenue();renderMenuPage();
    if(compactMode)document.body.classList.add('compact-mode');
    const savedTheme=localStorage.getItem('bida_pro_theme')||'dark';$('#themeSelect').value=savedTheme;applyTheme(savedTheme);
    const glassOn=localStorage.getItem('bida_pro_glass')==='true';$('#glassToggle').checked=glassOn;if(glassOn)document.body.classList.add('glass-mode');
    const spaceOn=localStorage.getItem('bida_pro_space')==='true';$('#spaceToggle').checked=spaceOn;if(spaceOn){document.body.classList.add('space-bg');$('#starsCanvas').style.display='block';initStars();}
    navigateTo('home');
    showGreetingModal();
  })();
</script>
